// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Role {
  id    String     @id @default(cuid())
  slug  String     @unique // "admin" | "member"
  users UserRole[]

  @@map("role")
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@map("user_role")
}

model User {
  id          String     @id @default(cuid())
  firstName   String
  lastName    String
  email       String
  userRoles   UserRole[]
  supabase_id String     @unique
  created_at  DateTime   @default(now())
  updated_at  DateTime   @default(now())

  @@map("user")
}

model Services {
  id           Int        @id @default(autoincrement())
  name        String
  description String
  basePrice   Float
  created_at  DateTime   @default(now())
  updated_at  DateTime   @default(now())
  quotation   Quotation? @relation("QuotationServices", fields: [quotationId], references: [id])
  quotationId Int?

  @@map("services")
}

model Quotation {
  id           Int        @id @default(autoincrement())
  name        String
  description String
  totalPrice   Float
  created_at  DateTime   @default(now())
  updated_at  DateTime   @default(now())
  services    Services[] @relation("QuotationServices")
  status      String     @default("draft") // "draft" | "sent" | "accepted" | "rejected"

  @@map("quotations")
}

model Studio {
  id          Int         @id @default(autoincrement())
  name        String
  location    String
  capacity    Int
  description String?
  isActive    Boolean     @default(true)
  equipment   Equipment[]
  bookings    StudioBooking[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("studios")
}

model Equipment {
  id          Int        @id @default(autoincrement())
  name        String
  type        String
  brand       String?
  model       String?
  serialNumber String?   @unique
  condition   String     @default("Good")
  isAvailable Boolean    @default(true)
  studioId    Int?
  studio      Studio?    @relation(fields: [studioId], references: [id])
  bookings    Booking[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("equipment")
}

model Booking {
  id          Int        @id @default(autoincrement())
  equipmentId Int
  equipment   Equipment  @relation(fields: [equipmentId], references: [id])
  bookedBy    String
  startDate   DateTime
  endDate     DateTime
  purpose     String?
  status      String     @default("active") // "active" | "cancelled" | "completed"
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("bookings")
}

model StudioBooking {
  id          Int        @id @default(autoincrement())
  studioId    Int
  studio      Studio     @relation(fields: [studioId], references: [id])
  bookedBy    String
  startDate   DateTime
  endDate     DateTime
  purpose     String?
  attendees   Int        @default(1)
  status      String     @default("active") // "active" | "cancelled" | "completed"
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("studio_bookings")
}
