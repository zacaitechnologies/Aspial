generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Role {
  id    String     @id @default(cuid())
  slug  String     @unique
  users UserRole[]

  @@map("role")
}

model UserRole {
  userId String
  roleId String
  role   Role   @relation(fields: [roleId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@id([userId, roleId])
  @@map("user_role")
}

model staffRole {
  id       String @id @default(cuid())
  roleName String
  users    User[]

  @@map("staff_role")
}

model User {
  id                             String                    @id @default(cuid())
  firstName                      String
  lastName                       String
  email                          String
  supabase_id                    String                    @unique
  profilePicture                 String?
  created_at                     DateTime                  @default(now())
  updated_at                     DateTime                  @default(now())
  staffRoleId                    String?
  staffRole                      staffRole?                @relation(fields: [staffRoleId], references: [id])
  reviewedCustomServices         CustomService[]           @relation("CustomServiceReviewer")
  createdCustomServices          CustomService[]           @relation("CustomServiceCreator")
  sentInvitations                ProjectInvitation[]       @relation("ProjectInviter")
  receivedInvitations            ProjectInvitation[]       @relation("ProjectInvitee")
  projectPermissions             ProjectPermission[]
  projects                       Project[]                 @relation("ProjectCreator")
  quotations                     Quotation[]               @relation("QuotationCreator")
  tasksAssigned                  Task[]                    @relation("TaskAssignee")
  assignedTasks                  Task[]                    @relation("TaskCreator")
  timeEntries                    TimeEntry[]
  userRoles                      UserRole[]
  complaints                     Complaint[]
  superPerformanceAwards        SuperPerformanceAward[]

  @@map("user")
}

model Complaint {
  id         Int             @id @default(autoincrement())
  date       DateTime        @default(now())
  customer   String
  reason     String
  userId     String
  projectId  Int?
  user       User            @relation(fields: [userId], references: [id])
  project    Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  created_at DateTime        @default(now())
  updated_at DateTime        @updatedAt

  @@map("complaints")
}

model Services {
  id           Int                @id @default(autoincrement())
  name         String
  description  String
  basePrice    Float
  created_at   DateTime           @default(now())
  updated_at   DateTime           @default(now())
  ServiceToTag ServiceToTag[]
  milestones   Milestone[]
  quotations   QuotationService[]
}

model ServiceTag {
  id           Int            @id @default(autoincrement())
  name         String         @unique
  color        String?        @default("#3B82F6")
  created_at   DateTime       @default(now())
  ServiceToTag ServiceToTag[]

  @@map("service_tags")
}

model Quotation {
  id             Int                @id @default(autoincrement())
  name           String
  description    String
  totalPrice     Float
  created_at     DateTime           @default(now())
  updated_at     DateTime           @default(now())
  workflowStatus QuotationStatus    @default(draft)
  createdById    String
  discountType   DiscountType?
  discountValue  Float?
  duration       Int
  endDate        DateTime
  startDate      DateTime
  clientId       String
  projectId      Int?
  paymentStatus  PaymentStatus      @default(unpaid)
  customServices CustomService[]
  services       QuotationService[]
  Client         Client             @relation(fields: [clientId], references: [id])
  createdBy      User               @relation("QuotationCreator", fields: [createdById], references: [supabase_id])
  project        Project?           @relation(fields: [projectId], references: [id])

  @@map("quotations")
}

enum PaymentStatus {
  unpaid
  partially_paid
  deposit_paid
  fully_paid
}

model QuotationService {
  id              Int            @id @default(autoincrement())
  quotationId     Int
  serviceId       Int
  customServiceId String?
  customService   CustomService? @relation(fields: [customServiceId], references: [id], onDelete: Cascade)
  quotation       Quotation      @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  service         Services       @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([quotationId, serviceId])
  @@unique([quotationId, customServiceId])
  @@map("quotation_services")
}

model CustomService {
  id                String              @id @default(cuid())
  name              String
  description       String
  price             Float
  status            CustomServiceStatus @default(PENDING)
  approvalComment   String?
  rejectionComment  String?
  reviewedById      String?
  createdById       String
  quotationId       Int
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  reviewedBy        User?               @relation("CustomServiceReviewer", fields: [reviewedById], references: [supabase_id], map: "custom_services_approvedById_fkey")
  createdBy         User                @relation("CustomServiceCreator", fields: [createdById], references: [supabase_id])
  quotation         Quotation           @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  quotationServices QuotationService[]

  @@map("custom_services")
}

model Project {
  id            Int                 @id @default(autoincrement())
  name          String
  description   String?
  status        ProjectStatus       @default(planning)
  startDate     DateTime
  endDate       DateTime
  created_at    DateTime            @default(now())
  updated_at    DateTime            @default(now())
  createdBy     String
  clientId      String
  clientName    String
  bookings      Booking[]
  studioBookings StudioBooking[] @relation("StudioBookingProject")
  milestones    Milestone[]
  invitations   ProjectInvitation[]
  permissions   ProjectPermission[]
  Client        Client              @relation(fields: [clientId], references: [id])
  createdByUser User                @relation("ProjectCreator", fields: [createdBy], references: [supabase_id])
  quotations    Quotation[]
  tasks         Task[]
  timeEntries   TimeEntry[]
  complaints    Complaint[]

  @@map("projects")
}

enum ProjectStatus {
  planning
  in_progress
  on_hold
  completed
  cancelled
}

model ProjectPermission {
  id        Int     @id @default(autoincrement())
  userId    String
  projectId Int
  canView   Boolean @default(true)
  canEdit   Boolean @default(true)
  isOwner   Boolean @default(false)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [supabase_id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@map("project_permissions")
}

model Client {
  id             String         @id @default(cuid())
  name           String
  email          String         @unique
  phone          String?
  company        String?
  address        String?
  notes          String?
  created_at     DateTime       @default(now())
  updated_at     DateTime       @default(now())
  industry       String?
  membershipType MembershipType @default(NON_MEMBER)
  yearlyRevenue  Float?
  projects       Project[]
  quotations     Quotation[]

  @@map("clients")
}

model Studio {
  id          Int             @id @default(autoincrement())
  name        String
  location    String
  capacity    Int
  description String?
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  bookings    StudioBooking[]

  @@map("studios")
}

model Equipment {
  id           Int       @id @default(autoincrement())
  name         String
  type         String
  brand        String?
  model        String?
  serialNumber String?   @unique
  condition    String    @default("Good")
  isAvailable  Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  bookings     Booking[]

  @@map("equipment")
}

model Booking {
  id          Int       @id @default(autoincrement())
  equipmentId Int
  bookedBy    String
  startDate   DateTime
  endDate     DateTime
  purpose     String?
  status      String    @default("active")
  projectId   Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@map("bookings")
}

model StudioBooking {
  id        Int      @id @default(autoincrement())
  studioId  Int
  bookedBy  String
  startDate DateTime
  endDate   DateTime
  purpose   String?
  attendees Int      @default(1)
  status    String   @default("active")
  projectId Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  studio    Studio   @relation(fields: [studioId], references: [id], onDelete: Cascade)
  project   Project? @relation("StudioBookingProject", fields: [projectId], references: [id], onDelete: SetNull)

  @@map("studio_bookings")
}

model TimeEntry {
  id          Int       @id @default(autoincrement())
  userId      String
  projectId   Int
  startTime   DateTime
  endTime     DateTime?
  duration    Int
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("time_entries")
}

model ProjectInvitation {
  id          Int              @id @default(autoincrement())
  projectId   Int
  invitedBy   String
  invitedUser String
  status      InvitationStatus @default(pending)
  canView     Boolean          @default(true)
  canEdit     Boolean          @default(true)
  isOwner     Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  inviter     User             @relation("ProjectInviter", fields: [invitedBy], references: [supabase_id], onDelete: Cascade)
  invitee     User             @relation("ProjectInvitee", fields: [invitedUser], references: [supabase_id], onDelete: Cascade)
  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, invitedUser])
  @@map("project_invitations")
}

model Milestone {
  id          Int             @id @default(autoincrement())
  title       String
  description String?
  projectId   Int
  serviceId   Int?
  dueDate     DateTime
  priority    TaskPriority    @default(low)
  status      MilestoneStatus @default(in_progress)
  order       Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  service     Services?       @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  tasks       Task[]

  @@map("milestones")
}

model Task {
  id          Int          @id @default(autoincrement())
  title       String
  description String?
  projectId   Int
  status      TaskStatus   @default(todo)
  priority    TaskPriority @default(low)
  creatorId   String
  dueDate     DateTime
  order       Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  startDate   DateTime
  milestoneId Int?
  assigneeId  String?
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [supabase_id])
  creator     User         @relation("TaskCreator", fields: [creatorId], references: [supabase_id])
  milestone   Milestone?   @relation(fields: [milestoneId], references: [id])
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("tasks")
}

model ServiceToTag {
  A            Int
  B            Int
  service_tags ServiceTag @relation(fields: [A], references: [id], onDelete: Cascade)
  Services     Services   @relation(fields: [B], references: [id], onDelete: Cascade)

  @@id([A, B], map: "_ServiceToTag_AB_pkey")
  @@index([B], map: "_ServiceToTag_B_index")
  @@map("_ServiceToTag")
}

enum MembershipType {
  MEMBER
  NON_MEMBER
}

enum QuotationStatus {
  draft
  in_review
  final
  accepted
  rejected
}

enum DiscountType {
  percentage
  fixed
}

enum TaskStatus {
  todo
  in_progress
  done
}

enum TaskPriority {
  low
  medium
  high
}

enum MilestoneStatus {
  not_started
  in_progress
  completed
}

enum InvitationStatus {
  pending
  accepted
  declined
  expired
}

enum CustomServiceStatus {
  PENDING
  APPROVED
  REJECTED
}

model SuperPerformanceAward {
  id             String   @id @default(cuid())
  userId         String
  year           Int
  hasAward       Boolean  @default(false)
  manualOverride Boolean  @default(false)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year])
  @@map("super_performance_awards")
}
