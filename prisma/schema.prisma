generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Role {
  id    String     @id @default(cuid())
  slug  String     @unique
  users UserRole[]

  @@map("role")
}

model UserRole {
  userId String
  roleId String
  role   Role   @relation(fields: [roleId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@id([userId, roleId])
  @@map("user_role")
}

model staffRole {
  id       String @id @default(cuid())
  roleName String
  users    User[]

  @@map("staff_role")
}

model User {
  id                       String                    @id @default(cuid())
  firstName                String
  lastName                 String
  email                    String
  supabase_id              String                    @unique
  profilePicture           String?
  created_at               DateTime                  @default(now())
  updated_at               DateTime                  @default(now())
  staffRoleId              String?
  staffRole                staffRole?                @relation(fields: [staffRoleId], references: [id])
  reviewedCustomServices   CustomService[]           @relation("CustomServiceReviewer")
  createdCustomServices    CustomService[]           @relation("CustomServiceCreator")
  sentInvitations          ProjectInvitation[]       @relation("ProjectInviter")
  receivedInvitations      ProjectInvitation[]       @relation("ProjectInvitee")
  projectPermissions       ProjectPermission[]
  projects                 Project[]                 @relation("ProjectCreator")
  quotations               Quotation[]               @relation("QuotationCreator")
  quotationEmails          QuotationEmail[]          @relation("QuotationEmailSender")
  invoices                 Invoice[]                 @relation("InvoiceCreator")
  invoiceEmails            InvoiceEmail[]            @relation("InvoiceEmailSender")
  receipts                 Receipt[]                 @relation("ReceiptCreator")
  receiptEmails            ReceiptEmail[]            @relation("ReceiptEmailSender")
  appointmentBookingEmails AppointmentBookingEmail[] @relation("AppointmentBookingEmailSender")
  tasksAssigned            Task[]                    @relation("TaskAssignee")
  assignedTasks            Task[]                    @relation("TaskCreator")
  timeEntries              TimeEntry[]
  userRoles                UserRole[]
  complaints               Complaint[]
  tierSelections           TierSelection[]
  contracts                Contract[]
  createdClients           Client[]                  @relation("ClientCreator")
  clientAdvisors           ClientAdvisor[]           @relation("ClientAdvisor")
  quotationAdvisors        QuotationAdvisor[]        @relation("QuotationAdvisor")
  invoiceAdvisors          InvoiceAdvisor[]          @relation("InvoiceAdvisor")
  invoicePhotographers     InvoicePhotographer[]     @relation("InvoicePhotographer")
  receiptAdvisors          ReceiptAdvisor[]          @relation("ReceiptAdvisor")
  deliveryOrdersCreated    DeliveryOrder[]           @relation("DeliveryOrderCreator")
  deliveryOrderAdvisors    DeliveryOrderAdvisor[]    @relation("DeliveryOrderAdvisor")
  deliveryOrderEmails      DeliveryOrderEmail[]      @relation("DeliveryOrderEmailSender")
  leaveApplications        LeaveApplication[]
  reviewedLeaves           LeaveApplication[]        @relation("LeaveReviewer")
  leaveBalances            LeaveBalance[]
  leaveChangeRequests      LeaveChangeRequest[]      @relation("ChangeRequestor")
  reviewedChangeRequests   LeaveChangeRequest[]      @relation("ChangeRequestReviewer")
  calendarBlockers         CalendarBlocker[]         @relation("CalendarBlockerCreator")
  appointmentBookings      AppointmentBooking[]      @relation("AppointmentBookingBooker")
  cancelledAppointmentBookings AppointmentBooking[]  @relation("AppointmentBookingCanceller")
  appointmentAssignments   AppointmentBookingAssignee[] @relation("AppointmentBookingAssignee")

  @@index([supabase_id])
  @@map("user")
}

model Complaint {
  id         Int      @id @default(autoincrement())
  date       DateTime @default(now())
  customer   String
  reason     String
  userId     String
  projectId  Int?
  user       User     @relation(fields: [userId], references: [id])
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("complaints")
}

model Services {
  id           Int                @id @default(autoincrement())
  name         String
  description  String
  basePrice    Float
  imageUrl     String?
  hidden       Boolean            @default(false)
  created_at   DateTime           @default(now())
  updated_at   DateTime           @default(now())
  ServiceToTag    ServiceToTag[]
  milestones      Milestone[]
  quotations      QuotationService[]
  deliveryOrders  DeliveryOrderService[]
  receiptServices ReceiptService[]

  @@index([hidden])
}

model ServiceTag {
  id           Int            @id @default(autoincrement())
  name         String         @unique
  color        String?        @default("#3B82F6")
  created_at   DateTime       @default(now())
  ServiceToTag ServiceToTag[]

  @@map("service_tags")
}

model Quotation {
  id             Int                @id @default(autoincrement())
  name           String             @unique
  description    String
  totalPrice     Float
  /// Business / document date (editable). Distinct from row audit timestamps.
  quotationDate  DateTime           @default(now()) @map("quotation_date")
  created_at     DateTime           @default(now())
  updated_at     DateTime           @default(now())
  workflowStatus QuotationStatus    @default(draft)
  createdById    String
  discountType   DiscountType?
  discountValue  Float?
  duration       Int
  endDate        DateTime
  startDate      DateTime
  clientId       String
  projectId      Int?
  paymentStatus  PaymentStatus      @default(unpaid)
  customServices CustomService[]
  services       QuotationService[]
  Client         Client             @relation(fields: [clientId], references: [id])
  createdBy      User               @relation("QuotationCreator", fields: [createdById], references: [supabase_id])
  project        Project?           @relation(fields: [projectId], references: [id])

  advisors QuotationAdvisor[]

  quotationEmails QuotationEmail[]
  invoices        Invoice[]

  @@map("quotations")
}

model QuotationCounter {
  month_prefix String @id // Format: YYYYMM (e.g., "202601")
  last_value   Int    @default(0)

  @@map("quotation_counters")
}

model InvoiceCounter {
  type       String @id // "SO" | "EPO" | "EO"
  last_value Int    @default(0)

  @@map("invoice_counters")
}

model ReceiptCounter {
  id         String @id @default("singleton")
  last_value Int    @default(0)

  @@map("receipt_counters")
}

model QuotationEmail {
  id             Int       @id @default(autoincrement())
  quotationId    Int
  quotation      Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  recipientEmail String
  sentAt         DateTime  @default(now())
  sentById       String
  sentBy         User      @relation("QuotationEmailSender", fields: [sentById], references: [supabase_id])

  @@map("quotation_emails")
}

model Invoice {
  id            String                @id @default(cuid())
  invoiceNumber String                @unique
  type          InvoiceType
  quotationId   Int
  amount        Float
  createdById   String
  status        InvoiceStatus         @default(active)
  /// Derived from active receipts vs amount; recalculated on receipt changes.
  paymentStatus PaymentStatus         @default(unpaid)
  /// Business / document date (editable by admin). Used for sales analytics.
  invoiceDate   DateTime              @default(now()) @map("invoice_date")
  created_at    DateTime              @default(now())
  updated_at    DateTime              @default(now())
  advisors      InvoiceAdvisor[]
  photographers InvoicePhotographer[]
  quotation     Quotation             @relation(fields: [quotationId], references: [id], onDelete: Restrict)
  createdBy     User                  @relation("InvoiceCreator", fields: [createdById], references: [supabase_id])
  invoiceEmails InvoiceEmail[]
  receipts      Receipt[]

  @@index([quotationId])
  @@index([type])
  @@index([created_at])
  @@index([status])
  @@index([paymentStatus])
  @@map("invoices")
}

model InvoiceEmail {
  id             Int      @id @default(autoincrement())
  invoiceId      String
  invoice        Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  recipientEmail String
  sentAt         DateTime @default(now())
  sentById       String
  sentBy         User     @relation("InvoiceEmailSender", fields: [sentById], references: [supabase_id])

  @@map("invoice_emails")
}

model Receipt {
  id            String           @id @default(cuid())
  receiptNumber String           @unique
  invoiceId     String?
  clientId      String?
  amount        Float
  createdById   String
  status        ReceiptStatus    @default(active)
  /// Business / document date (editable by admin). Used for reporting.
  receiptDate   DateTime         @default(now()) @map("receipt_date")
  created_at    DateTime         @default(now())
  updated_at    DateTime         @default(now())
  paymentMethod PaymentMethod    @default(bank_transfer)
  /// Internal note — not shown on the PDF.
  remarks       String?
  advisors      ReceiptAdvisor[]
  services      ReceiptService[]
  invoice       Invoice?         @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  client        Client?          @relation("ClientReceipts", fields: [clientId], references: [id], onDelete: Restrict)
  createdBy     User             @relation("ReceiptCreator", fields: [createdById], references: [supabase_id])
  receiptEmails ReceiptEmail[]

  @@index([invoiceId])
  @@index([clientId])
  @@index([created_at])
  @@index([status])
  @@map("receipts")
}

model ReceiptService {
  id                  Int      @id @default(autoincrement())
  receiptId           String
  serviceId           Int
  /// Per-receipt description override; snapshotted from Services.description at creation,
  /// editable on this receipt only, never written back to Services.
  descriptionOverride String
  price               Float    @default(0)
  quantity            Int      @default(1)
  sortOrder           Int      @default(0)
  receipt             Receipt  @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  service             Services @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@index([receiptId])
  @@map("receipt_services")
}

model ReceiptEmail {
  id             Int      @id @default(autoincrement())
  receiptId      String
  receipt        Receipt  @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  recipientEmail String
  sentAt         DateTime @default(now())
  sentById       String
  sentBy         User     @relation("ReceiptEmailSender", fields: [sentById], references: [supabase_id])

  @@map("receipt_emails")
}

enum InvoiceType {
  SO
  EPO
  EO
}

enum InvoiceStatus {
  active
  cancelled
}

enum ReceiptStatus {
  active
  cancelled
}

enum PaymentMethod {
  cash
  bank_transfer
  mydebit
  visa
  mastercard
  qr
}

enum PaymentStatus {
  unpaid
  partially_paid
  deposit_paid
  fully_paid
}

model QuotationService {
  id                  Int            @id @default(autoincrement())
  quotationId         Int
  serviceId           Int? // null when row links a custom service (customServiceId set)
  customServiceId     String?
  /// Per-quotation description override; snapshotted from Services.description at creation,
  /// editable on this quotation only, never written back to Services. Null for custom service rows.
  descriptionOverride String?
  price               Float          @default(0)
  quantity            Int            @default(1)
  /// Explicit display/PDF order for this line. Lower values appear first.
  sortOrder           Int            @default(0)
  customService       CustomService? @relation(fields: [customServiceId], references: [id], onDelete: Cascade)
  quotation           Quotation      @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  service             Services?      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([quotationId, serviceId])
  @@unique([quotationId, customServiceId])
  @@map("quotation_services")
}

model CustomService {
  id                String              @id @default(cuid())
  name              String
  description       String
  price             Float
  status            CustomServiceStatus @default(PENDING)
  approvalComment   String?
  rejectionComment  String?
  reviewedById      String?
  createdById       String
  quotationId       Int
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  reviewedBy        User?               @relation("CustomServiceReviewer", fields: [reviewedById], references: [supabase_id], map: "custom_services_approvedById_fkey")
  createdBy         User                @relation("CustomServiceCreator", fields: [createdById], references: [supabase_id])
  quotation         Quotation           @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  quotationServices QuotationService[]

  @@map("custom_services")
}

model Project {
  id            Int                  @id @default(autoincrement())
  name          String
  description   String?
  status        ProjectStatus        @default(planning)
  startDate     DateTime
  endDate       DateTime
  created_at    DateTime             @default(now())
  updated_at    DateTime             @default(now())
  createdBy     String
  clientId      String
  clientName    String
  appointments  AppointmentBooking[] @relation("AppointmentBookingProject")
  milestones    Milestone[]
  invitations   ProjectInvitation[]
  permissions   ProjectPermission[]
  contracts     Contract[]
  Client        Client               @relation(fields: [clientId], references: [id])
  createdByUser User                 @relation("ProjectCreator", fields: [createdBy], references: [supabase_id])
  quotations    Quotation[]
  tasks         Task[]
  timeEntries   TimeEntry[]
  complaints    Complaint[]
  deliveryOrders DeliveryOrder[]

  @@index([created_at])
  @@index([status])
  @@index([createdBy])
  @@map("projects")
}

enum ProjectStatus {
  planning
  in_progress
  on_hold
  completed
  cancelled
}

model ProjectPermission {
  id        Int     @id @default(autoincrement())
  userId    String
  projectId Int
  canView   Boolean @default(true)
  canEdit   Boolean @default(true)
  isOwner   Boolean @default(false)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [supabase_id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([userId])
  @@index([projectId])
  @@index([userId, isOwner])
  @@index([userId, canView])
  @@map("project_permissions")
}

model Client {
  id                        String          @id @default(cuid())
  name                      String
  email                     String
  phone                     String?
  company                   String?
  companyRegistrationNumber String?
  ic                        String?
  address                   String?
  notes                     String?
  created_at                DateTime        @default(now())
  updated_at                DateTime        @default(now())
  industry                  String?
  membershipType            MembershipType  @default(NON_MEMBER)
  yearlyRevenue             Float?
  createdById               String
  createdBy                 User            @relation("ClientCreator", fields: [createdById], references: [id], onDelete: Restrict, onUpdate: Cascade)
  advisors                  ClientAdvisor[]
  projects                  Project[]
  quotations                Quotation[]
  deliveryOrders            DeliveryOrder[]
  receipts                  Receipt[]       @relation("ClientReceipts")

  @@map("clients")
}

model ClientAdvisor {
  clientId String
  userId   String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user     User   @relation("ClientAdvisor", fields: [userId], references: [id], onDelete: Cascade)

  @@id([clientId, userId])
  @@map("client_advisors")
}

model QuotationAdvisor {
  quotationId Int
  userId      String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  user        User      @relation("QuotationAdvisor", fields: [userId], references: [id], onDelete: Cascade)

  @@id([quotationId, userId])
  @@map("quotation_advisors")
}

model InvoiceAdvisor {
  invoiceId String
  userId    String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  user      User    @relation("InvoiceAdvisor", fields: [userId], references: [id], onDelete: Cascade)

  @@id([invoiceId, userId])
  @@map("invoice_advisors")
}

model InvoicePhotographer {
  invoiceId String
  userId    String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  user      User    @relation("InvoicePhotographer", fields: [userId], references: [id], onDelete: Cascade)

  @@id([invoiceId, userId])
  @@map("invoice_photographers")
}

model ReceiptAdvisor {
  receiptId String
  userId    String
  receipt   Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  user      User    @relation("ReceiptAdvisor", fields: [userId], references: [id], onDelete: Cascade)

  @@id([receiptId, userId])
  @@map("receipt_advisors")
}

model DeliveryOrder {
  id                  String              @id @default(cuid())
  deliveryOrderNumber String              @unique
  clientId            String
  notes               String?
  discountType        DiscountType?
  discountValue       Float?
  totalAmount         Float               @default(0)
  finalAmount         Float               @default(0)
  status              DeliveryOrderStatus @default(active)
  /// Business / document date (editable). Shown on the PDF as "DATE".
  deliveryOrderDate   DateTime            @default(now()) @map("delivery_order_date")
  created_at          DateTime            @default(now())
  updated_at          DateTime            @default(now()) @updatedAt
  createdById         String
  projectId           Int?

  client    Client                 @relation(fields: [clientId], references: [id])
  createdBy User                   @relation("DeliveryOrderCreator", fields: [createdById], references: [supabase_id])
  project   Project?               @relation(fields: [projectId], references: [id], onDelete: SetNull)
  services  DeliveryOrderService[]
  advisors  DeliveryOrderAdvisor[]
  emails    DeliveryOrderEmail[]

  @@index([clientId])
  @@index([created_at])
  @@index([status])
  @@index([projectId])
  @@map("delivery_orders")
}

model DeliveryOrderService {
  id                  Int    @id @default(autoincrement())
  deliveryOrderId     String
  serviceId           Int
  /// Per-DO description override; snapshotted from Services.description at creation,
  /// editable on this DO only, never written back to Services.
  descriptionOverride String
  price               Float  @default(0)
  quantity            Int    @default(1)
  sortOrder           Int    @default(0)

  deliveryOrder DeliveryOrder @relation(fields: [deliveryOrderId], references: [id], onDelete: Cascade)
  service       Services      @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@index([deliveryOrderId])
  @@map("delivery_order_services")
}

model DeliveryOrderAdvisor {
  deliveryOrderId String
  userId          String
  deliveryOrder   DeliveryOrder @relation(fields: [deliveryOrderId], references: [id], onDelete: Cascade)
  user            User          @relation("DeliveryOrderAdvisor", fields: [userId], references: [id], onDelete: Cascade)

  @@id([deliveryOrderId, userId])
  @@map("delivery_order_advisors")
}

model DeliveryOrderEmail {
  id              Int           @id @default(autoincrement())
  deliveryOrderId String
  deliveryOrder   DeliveryOrder @relation(fields: [deliveryOrderId], references: [id], onDelete: Cascade)
  recipientEmail  String
  sentAt          DateTime      @default(now())
  sentById        String
  sentBy          User          @relation("DeliveryOrderEmailSender", fields: [sentById], references: [supabase_id])

  @@map("delivery_order_emails")
}

model DeliveryOrderCounter {
  month_prefix String @id
  last_value   Int    @default(0)

  @@map("delivery_order_counters")
}

enum DeliveryOrderStatus {
  active
  cancelled
}

model Appointment {
  id              Int                  @id @default(autoincrement())
  name            String
  location        String?
  brand           String?
  description     String?
  appointmentType AppointmentType      @default(OTHERS)
  isAvailable     Boolean              @default(true)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  bookings        AppointmentBooking[]

  @@map("appointments")
}

model AppointmentBooking {
  id              Int                          @id @default(autoincrement())
  bookedBy        String
  userId          String?
  startDate       DateTime
  endDate         DateTime
  purpose             String?
  appointmentType     AppointmentType              @default(OTHERS)
  appointmentCategory AppointmentCategory          @default(INTERNAL)
  status              String                       @default("active")
  projectId       Int?
  appointmentId   Int?
  attendees       Int?
  bookingName     String?
  companyName     String?
  contactNumber   String?
  remarks         String?
  cancellationReason String?
  cancelledAt     DateTime?
  cancelledById   String?
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt
  appointment     Appointment?                 @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  project         Project?                     @relation("AppointmentBookingProject", fields: [projectId], references: [id], onDelete: SetNull)
  bookedByUser    User?                        @relation("AppointmentBookingBooker", fields: [userId], references: [supabase_id], onDelete: SetNull, onUpdate: Cascade)
  cancelledByUser User?                        @relation("AppointmentBookingCanceller", fields: [cancelledById], references: [supabase_id], onDelete: SetNull, onUpdate: Cascade)
  bookingEmails   AppointmentBookingEmail[]
  reminders       AppointmentBookingReminder[]
  assignees       AppointmentBookingAssignee[]

  @@index([userId])
  @@map("appointment_bookings")
}

model AppointmentBookingAssignee {
  bookingId Int
  userId    String
  booking   AppointmentBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user      User               @relation("AppointmentBookingAssignee", fields: [userId], references: [supabase_id], onDelete: Cascade, onUpdate: Cascade)

  @@id([bookingId, userId])
  @@index([userId])
  @@map("appointment_booking_assignees")
}

model AppointmentBookingEmail {
  id                   Int                @id @default(autoincrement())
  appointmentBookingId Int
  appointmentBooking   AppointmentBooking @relation(fields: [appointmentBookingId], references: [id], onDelete: Cascade)
  recipientEmail       String
  sentAt               DateTime           @default(now())
  sentById             String?
  sentBy               User?              @relation("AppointmentBookingEmailSender", fields: [sentById], references: [supabase_id])
  isAutomated          Boolean            @default(false) // true for automated reminders, false for manual

  @@map("appointment_booking_emails")
}

enum ReminderStatus {
  PENDING
  SENDING
  SENT
  FAILED
}

model AppointmentBookingReminder {
  id                   Int                @id @default(autoincrement())
  appointmentBookingId Int
  appointmentBooking   AppointmentBooking @relation(fields: [appointmentBookingId], references: [id], onDelete: Cascade)
  offsetMinutes        Int // Minutes before startDate (e.g., 60 for 1 hour, 2880 for 48 hours)
  recipientEmail       String // Email address to send reminder to
  remindAt             DateTime // Computed: startDate - offsetMinutes
  status               ReminderStatus     @default(PENDING)
  sentAt               DateTime?
  lastAttemptAt        DateTime?
  attemptCount         Int                @default(0)
  lastError            String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@unique([appointmentBookingId, offsetMinutes, recipientEmail])
  @@index([status])
  @@index([remindAt, status])
  @@map("appointment_booking_reminders")
}

model TimeEntry {
  id          Int       @id @default(autoincrement())
  userId      String
  projectId   Int
  taskId      Int?
  startTime   DateTime
  endTime     DateTime?
  duration    Int
  description String?
  isActive    Boolean   @default(false)
  isPause     Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task        Task?     @relation(fields: [taskId], references: [id], onDelete: SetNull)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("time_entries")
}

model ProjectInvitation {
  id          Int              @id @default(autoincrement())
  projectId   Int
  invitedBy   String
  invitedUser String
  status      InvitationStatus @default(pending)
  canView     Boolean          @default(true)
  canEdit     Boolean          @default(true)
  isOwner     Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  inviter     User             @relation("ProjectInviter", fields: [invitedBy], references: [supabase_id], onDelete: Cascade)
  invitee     User             @relation("ProjectInvitee", fields: [invitedUser], references: [supabase_id], onDelete: Cascade)
  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, invitedUser])
  @@map("project_invitations")
}

model Milestone {
  id          Int             @id @default(autoincrement())
  title       String
  description String?
  projectId   Int
  serviceId   Int?
  /// Pastel color key (e.g. pastel-sky, pastel-mint) for UI differentiation
  color       String          @default("pastel-sky")
  dueDate     DateTime
  priority    TaskPriority    @default(low)
  status      MilestoneStatus @default(in_progress)
  order       Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  service     Services?       @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  tasks       Task[]

  @@map("milestones")
}

model Task {
  id          Int          @id @default(autoincrement())
  title       String
  description String?
  projectId   Int
  status      TaskStatus   @default(todo)
  priority    TaskPriority @default(low)
  creatorId   String
  dueDate     DateTime
  order       Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  startDate   DateTime
  milestoneId Int?
  assigneeId  String?
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [supabase_id])
  creator     User         @relation("TaskCreator", fields: [creatorId], references: [supabase_id])
  milestone   Milestone?   @relation(fields: [milestoneId], references: [id])
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  timeEntries TimeEntry[]

  @@map("tasks")
}

model ServiceToTag {
  A            Int
  B            Int
  service_tags ServiceTag @relation(fields: [A], references: [id], onDelete: Cascade)
  Services     Services   @relation(fields: [B], references: [id], onDelete: Cascade)

  @@id([A, B], map: "_ServiceToTag_AB_pkey")
  @@index([B], map: "_ServiceToTag_B_index")
  @@map("_ServiceToTag")
}

enum MembershipType {
  MEMBER
  NON_MEMBER
}

enum QuotationStatus {
  draft
  final
  cancelled
}

enum DiscountType {
  percentage
  fixed
}

enum TaskStatus {
  todo
  in_progress
  done
}

enum TaskPriority {
  low
  medium
  high
}

enum MilestoneStatus {
  not_started
  in_progress
  completed
}

enum InvitationStatus {
  pending
  accepted
  declined
  expired
  removed
}

enum CustomServiceStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BenefitTier {
  TIER_1
  TIER_2
  TIER_3
  TIER_4
}

enum AppointmentType {
  PHOTO_SHOOT
  VIDEO_SHOOT
  CONSULTATION
  PHOTO_SELECTION
  OTHERS
}

enum AppointmentCategory {
  INTERNAL
  EXTERNAL
}

model TierSelection {
  id            String      @id @default(cuid())
  userId        String
  year          Int
  tier          BenefitTier
  customTarget  Int? // Custom monthly target for Tier 1 (50k-70k)
  selectedAt    DateTime    @default(now())
  adminOverride Boolean     @default(false)
  adminNote     String?
  created_at    DateTime    @default(now())
  updated_at    DateTime    @updatedAt
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year])
  @@map("tier_selections")
}

model Contract {
  id         String   @id @default(cuid())
  projectId  Int
  fileName   String
  filePath   String
  uploadedBy String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploader   User     @relation(fields: [uploadedBy], references: [supabase_id], onDelete: Cascade)

  @@map("contracts")
}

// Leave Application Module

model LeaveType {
  id                      Int      @id @default(autoincrement())
  code                    String   @unique
  name                    String
  defaultEntitlement      Float    @default(0)
  isDeletable             Boolean  @default(true)
  isUnpaid                Boolean  @default(false)
  requiresReplacementDate Boolean  @default(false)
  requiresAttachment      Boolean  @default(false)
  sortOrder               Int      @default(0)
  isActive                Boolean  @default(true)
  created_at              DateTime @default(now())
  updated_at              DateTime @updatedAt

  applications LeaveApplication[]
  balances     LeaveBalance[]

  @@map("leave_type")
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum LeaveHalfDay {
  NONE
  FIRST_HALF
  SECOND_HALF
}

enum ChangeRequestType {
  CANCEL
  EDIT
}

enum ChangeRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model LeaveApplication {
  id             Int                  @id @default(autoincrement())
  userId         String
  user           User                 @relation(fields: [userId], references: [id])
  leaveType      String
  leaveTypeRel   LeaveType            @relation(fields: [leaveType], references: [code])
  startDate      DateTime
  endDate        DateTime
  halfDay        LeaveHalfDay         @default(NONE)
  reason         String
  attachmentUrl  String?
  status         LeaveStatus          @default(PENDING)
  adminRemarks   String?
  reviewedById   String?
  reviewedBy     User?                @relation("LeaveReviewer", fields: [reviewedById], references: [id])
  reviewedAt     DateTime?
  totalDays      Float
  unpaidDays     Float                @default(0)
  created_at     DateTime             @default(now())
  updated_at     DateTime             @updatedAt
  changeRequests LeaveChangeRequest[]

  @@index([userId])
  @@index([status])
  @@index([leaveType])
  @@map("leave_application")
}

model LeaveBalance {
  id           Int       @id @default(autoincrement())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  leaveType    String
  leaveTypeRel LeaveType @relation(fields: [leaveType], references: [code])
  year         Int
  entitled     Float
  used         Float     @default(0)
  pending      Float     @default(0)
  balance      Float

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([userId, leaveType, year])
  @@index([userId, year])
  @@index([leaveType])
  @@map("leave_balance")
}

model LeaveChangeRequest {
  id                 Int                 @id @default(autoincrement())
  leaveApplicationId Int
  leaveApplication   LeaveApplication    @relation(fields: [leaveApplicationId], references: [id])
  requestedById      String
  requestedBy        User                @relation("ChangeRequestor", fields: [requestedById], references: [id])
  type               ChangeRequestType
  status             ChangeRequestStatus @default(PENDING)
  reason             String
  newStartDate       DateTime?
  newEndDate         DateTime?
  newLeaveType       String?
  newHalfDay         LeaveHalfDay?
  newReason          String?
  adminRemarks       String?
  reviewedById       String?
  reviewedBy         User?               @relation("ChangeRequestReviewer", fields: [reviewedById], references: [id])
  reviewedAt         DateTime?
  created_at         DateTime            @default(now())
  updated_at         DateTime            @updatedAt

  @@index([leaveApplicationId])
  @@map("leave_change_request")
}

model CalendarBlocker {
  id                 Int      @id @default(autoincrement())
  title              String
  description        String?
  startDateTime      DateTime
  endDateTime        DateTime
  blocksAppointments Boolean  @default(false)
  createdById        String
  createdBy          User     @relation("CalendarBlockerCreator", fields: [createdById], references: [supabase_id])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("calendar_blockers")
}
