generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model Role {
  id    String     @id @default(cuid())
  slug  String     @unique
  users UserRole[]

  @@map("role")
}

model UserRole {
  userId String
  roleId String
  role   Role   @relation(fields: [roleId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@id([userId, roleId])
  @@map("user_role")
}

model User {
  id                  String              @id @default(cuid())
  firstName           String
  lastName            String
  email               String
  supabase_id         String              @unique
  created_at          DateTime            @default(now())
  updated_at          DateTime            @default(now())
  sentInvitations     ProjectInvitation[] @relation("ProjectInviter")
  receivedInvitations ProjectInvitation[] @relation("ProjectInvitee")
  projectPermissions  ProjectPermission[]
  projects            Project[]           @relation("ProjectCreator")
  quotations          Quotation[]         @relation("QuotationCreator")
  assignedTasks       Task[]              @relation("TaskCreator")
  tasksAssigned       Task[]              @relation("TaskAssignee")
  timeEntries         TimeEntry[]
  userRoles           UserRole[]

  @@map("user")
}

model Services {
  id          Int                @id @default(autoincrement())
  name        String
  description String
  basePrice   Float
  created_at  DateTime           @default(now())
  updated_at  DateTime           @default(now())
  quotations  QuotationService[]
  tags        ServiceTag[]       @relation("ServiceTags")
}

model ServiceTag {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  color     String?   @default("#3B82F6") // Default blue color
  created_at DateTime @default(now())
  services  Services[] @relation("ServiceTags")

  @@map("service_tags")
}

model Quotation {
  id            Int                @id @default(autoincrement())
  name          String
  description   String
  totalPrice    Float
  created_at    DateTime           @default(now())
  updated_at    DateTime           @default(now())
  status        QuotationStatus    @default(draft)
  createdById   String
  discountType  DiscountType?
  discountValue Float?
  duration      Int
  endDate       DateTime
  startDate     DateTime
  clientId      String
  projectId     Int?
  services      QuotationService[]
  Client        Client             @relation(fields: [clientId], references: [id])
  createdBy     User               @relation("QuotationCreator", fields: [createdById], references: [supabase_id])
  project       Project?           @relation(fields: [projectId], references: [id])

  @@map("quotations")
}

model QuotationService {
  id          Int       @id @default(autoincrement())
  quotationId Int
  serviceId   Int
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  service     Services  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([quotationId, serviceId])
  @@map("quotation_services")
}

model Project {
  id            Int                 @id @default(autoincrement())
  name          String
  description   String?
  status        String              @default("planning")
  startDate     DateTime
  endDate       DateTime
  created_at    DateTime            @default(now())
  updated_at    DateTime            @default(now())
  createdBy     String
  clientId      String
  clientName    String
  milestones    Milestone[]
  invitations   ProjectInvitation[]
  permissions   ProjectPermission[]
  Client        Client              @relation(fields: [clientId], references: [id])
  createdByUser User                @relation("ProjectCreator", fields: [createdBy], references: [supabase_id])
  quotations    Quotation[]
  tasks         Task[]
  timeEntries   TimeEntry[]

  @@map("projects")
}

model ProjectPermission {
  id        Int     @id @default(autoincrement())
  userId    String
  projectId Int
  canView   Boolean @default(true)
  canEdit   Boolean @default(true)
  isOwner   Boolean @default(false)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [supabase_id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@map("project_permissions")
}

model Client {
  id         String      @id @default(cuid())
  name       String
  email      String      @unique
  phone      String?
  company    String?
  address    String?
  notes      String?
  created_at DateTime    @default(now())
  updated_at DateTime    @default(now())
  projects   Project[]
  quotations Quotation[]

  @@map("clients")
}

model Studio {
  id          Int             @id @default(autoincrement())
  name        String
  location    String
  capacity    Int
  description String?
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  bookings    StudioBooking[]

  @@map("studios")
}

model Equipment {
  id           Int       @id @default(autoincrement())
  name         String
  type         String
  brand        String?
  model        String?
  serialNumber String?   @unique
  condition    String    @default("Good")
  isAvailable  Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  bookings     Booking[]

  @@map("equipment")
}

model Booking {
  id          Int       @id @default(autoincrement())
  equipmentId Int
  bookedBy    String
  startDate   DateTime
  endDate     DateTime
  purpose     String?
  status      String    @default("active")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@map("bookings")
}

model StudioBooking {
  id        Int      @id @default(autoincrement())
  studioId  Int
  bookedBy  String
  startDate DateTime
  endDate   DateTime
  purpose   String?
  attendees Int      @default(1)
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  studio    Studio   @relation(fields: [studioId], references: [id], onDelete: Cascade)

  @@map("studio_bookings")
}

model TimeEntry {
  id          Int       @id @default(autoincrement())
  userId      String
  projectId   Int
  startTime   DateTime
  endTime     DateTime?
  duration    Int
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("time_entries")
}

model ProjectInvitation {
  id          Int              @id @default(autoincrement())
  projectId   Int
  invitedBy   String
  invitedUser String
  status      InvitationStatus @default(pending)
  canView     Boolean          @default(true)
  canEdit     Boolean          @default(true)
  isOwner     Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  inviter     User             @relation("ProjectInviter", fields: [invitedBy], references: [supabase_id], onDelete: Cascade)
  invitee     User             @relation("ProjectInvitee", fields: [invitedUser], references: [supabase_id], onDelete: Cascade)
  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, invitedUser])
  @@map("project_invitations")
}

model Milestone {
  id          Int             @id @default(autoincrement())
  title       String
  description String?
  projectId   Int
  dueDate     DateTime
  priority    TaskPriority    @default(low)
  status      MilestoneStatus @default(in_progress)
  order       Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks       Task[]

  @@map("milestones")
}

model Task {
  id          Int          @id @default(autoincrement())
  title       String
  description String?
  projectId   Int
  status      TaskStatus   @default(todo)
  priority    TaskPriority @default(low)
  creatorId   String
  assigneeId  String?
  dueDate     DateTime
  order       Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  startDate   DateTime
  milestoneId Int?
  creator     User         @relation("TaskCreator", fields: [creatorId], references: [supabase_id])
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [supabase_id])
  milestone   Milestone?   @relation(fields: [milestoneId], references: [id])
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("tasks")
}

enum QuotationStatus {
  draft
  accepted
  rejected
  paid
  unpaid
  partially_paid
  deposit_paid
}

enum DiscountType {
  percentage
  fixed
}

enum TaskStatus {
  todo
  in_progress
  done
}

enum TaskPriority {
  low
  medium
  high
}

enum MilestoneStatus {
  not_started
  in_progress
  completed
}

enum InvitationStatus {
  pending
  accepted
  declined
  expired
}
