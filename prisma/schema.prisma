generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Role {
  id    String     @id @default(cuid())
  slug  String     @unique
  users UserRole[]

  @@map("role")
}

model UserRole {
  userId String
  roleId String
  role   Role   @relation(fields: [roleId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@id([userId, roleId])
  @@map("user_role")
}

model staffRole {
  id       String @id @default(cuid())
  roleName String
  users    User[]

  @@map("staff_role")
}

model User {
  id                             String                    @id @default(cuid())
  firstName                      String
  lastName                       String
  email                          String
  supabase_id                    String                    @unique
  profilePicture                 String?
  created_at                     DateTime                  @default(now())
  updated_at                     DateTime                  @default(now())
  staffRoleId                    String?
  staffRole                      staffRole?                @relation(fields: [staffRoleId], references: [id])
  reviewedCustomServices         CustomService[]           @relation("CustomServiceReviewer")
  createdCustomServices          CustomService[]           @relation("CustomServiceCreator")
  sentInvitations                ProjectInvitation[]       @relation("ProjectInviter")
  receivedInvitations            ProjectInvitation[]       @relation("ProjectInvitee")
  projectPermissions             ProjectPermission[]
  projects                       Project[]                 @relation("ProjectCreator")
  quotations                     Quotation[]               @relation("QuotationCreator")
  quotationEmails                QuotationEmail[]          @relation("QuotationEmailSender")
  invoices                       Invoice[]                 @relation("InvoiceCreator")
  invoiceEmails                  InvoiceEmail[]             @relation("InvoiceEmailSender")
  receipts                       Receipt[]                 @relation("ReceiptCreator")
  receiptEmails                  ReceiptEmail[]            @relation("ReceiptEmailSender")
  tasksAssigned                  Task[]                    @relation("TaskAssignee")
  assignedTasks                  Task[]                    @relation("TaskCreator")
  timeEntries                    TimeEntry[]
  userRoles                      UserRole[]
  complaints                     Complaint[]
  tierSelections                 TierSelection[]
  contracts                      Contract[]
  createdClients                 Client[]                  @relation("ClientCreator")

  @@index([supabase_id])
  @@map("user")
}

model Complaint {
  id         Int             @id @default(autoincrement())
  date       DateTime        @default(now())
  customer   String
  reason     String
  userId     String
  projectId  Int?
  user       User            @relation(fields: [userId], references: [id])
  project    Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  created_at DateTime        @default(now())
  updated_at DateTime        @updatedAt

  @@map("complaints")
}

model Services {
  id           Int                @id @default(autoincrement())
  name         String
  description  String
  basePrice    Float
  imageUrl     String?
  created_at   DateTime           @default(now())
  updated_at   DateTime           @default(now())
  ServiceToTag ServiceToTag[]
  milestones   Milestone[]
  quotations   QuotationService[]
}

model ServiceTag {
  id           Int            @id @default(autoincrement())
  name         String         @unique
  color        String?        @default("#3B82F6")
  created_at   DateTime       @default(now())
  ServiceToTag ServiceToTag[]

  @@map("service_tags")
}

model Quotation {
  id             Int                @id @default(autoincrement())
  name           String             @unique
  description    String
  totalPrice     Float
  created_at     DateTime           @default(now())
  updated_at     DateTime           @default(now())
  workflowStatus QuotationStatus    @default(draft)
  createdById    String
  discountType   DiscountType?
  discountValue  Float?
  duration       Int
  endDate        DateTime
  startDate      DateTime
  clientId       String
  projectId      Int?
  paymentStatus  PaymentStatus      @default(unpaid)
  customServices CustomService[]
  services       QuotationService[]
  Client         Client             @relation(fields: [clientId], references: [id])
  createdBy      User               @relation("QuotationCreator", fields: [createdById], references: [supabase_id])
  project        Project?           @relation(fields: [projectId], references: [id])

  quotationEmails QuotationEmail[]
  invoices        Invoice[]

  @@map("quotations")
}

model QuotationEmail {
  id          Int       @id @default(autoincrement())
  quotationId Int
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  recipientEmail String
  sentAt       DateTime  @default(now())
  sentById    String
  sentBy       User      @relation("QuotationEmailSender", fields: [sentById], references: [supabase_id])

  @@map("quotation_emails")
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  type          InvoiceType
  quotationId   Int
  amount        Float
  createdById   String
  created_at    DateTime      @default(now())
  updated_at    DateTime      @default(now())
  quotation     Quotation     @relation(fields: [quotationId], references: [id], onDelete: Restrict)
  createdBy     User          @relation("InvoiceCreator", fields: [createdById], references: [supabase_id])
  invoiceEmails InvoiceEmail[]
  receipts      Receipt[]

  @@index([quotationId])
  @@index([type])
  @@index([created_at])
  @@map("invoices")
}

model InvoiceEmail {
  id            Int       @id @default(autoincrement())
  invoiceId     String
  invoice       Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  recipientEmail String
  sentAt        DateTime  @default(now())
  sentById      String
  sentBy        User      @relation("InvoiceEmailSender", fields: [sentById], references: [supabase_id])

  @@map("invoice_emails")
}

model Receipt {
  id            String        @id @default(cuid())
  receiptNumber String        @unique
  invoiceId     String
  amount        Float
  createdById   String
  created_at    DateTime      @default(now())
  updated_at    DateTime      @default(now())
  invoice       Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  createdBy     User          @relation("ReceiptCreator", fields: [createdById], references: [supabase_id])
  receiptEmails ReceiptEmail[]

  @@index([invoiceId])
  @@index([created_at])
  @@map("receipts")
}

model ReceiptEmail {
  id            Int       @id @default(autoincrement())
  receiptId     String
  receipt       Receipt   @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  recipientEmail String
  sentAt        DateTime  @default(now())
  sentById      String
  sentBy        User      @relation("ReceiptEmailSender", fields: [sentById], references: [supabase_id])

  @@map("receipt_emails")
}

enum InvoiceType {
  SO
  EPO
  EO
}

enum PaymentStatus {
  unpaid
  partially_paid
  deposit_paid
  fully_paid
}

model QuotationService {
  id              Int            @id @default(autoincrement())
  quotationId     Int
  serviceId       Int
  customServiceId String?
  customService   CustomService? @relation(fields: [customServiceId], references: [id], onDelete: Cascade)
  quotation       Quotation      @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  service         Services       @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([quotationId, serviceId])
  @@unique([quotationId, customServiceId])
  @@map("quotation_services")
}

model CustomService {
  id                String              @id @default(cuid())
  name              String
  description       String
  price             Float
  status            CustomServiceStatus @default(PENDING)
  approvalComment   String?
  rejectionComment  String?
  reviewedById      String?
  createdById       String
  quotationId       Int
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  reviewedBy        User?               @relation("CustomServiceReviewer", fields: [reviewedById], references: [supabase_id], map: "custom_services_approvedById_fkey")
  createdBy         User                @relation("CustomServiceCreator", fields: [createdById], references: [supabase_id])
  quotation         Quotation           @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  quotationServices QuotationService[]

  @@map("custom_services")
}

model Project {
  id            Int                 @id @default(autoincrement())
  name          String
  description   String?
  status        ProjectStatus       @default(planning)
  startDate     DateTime
  endDate       DateTime
  created_at    DateTime               @default(now())
  updated_at    DateTime               @default(now())
  createdBy     String
  clientId      String
  clientName    String
  appointments  AppointmentBooking[]   @relation("AppointmentBookingProject")
  milestones    Milestone[]
  invitations   ProjectInvitation[]
  permissions   ProjectPermission[]
  contracts     Contract[]
  Client        Client                 @relation(fields: [clientId], references: [id])
  createdByUser User                   @relation("ProjectCreator", fields: [createdBy], references: [supabase_id])
  quotations    Quotation[]
  tasks         Task[]
  timeEntries   TimeEntry[]
  complaints    Complaint[]

  @@index([created_at])
  @@index([status])
  @@index([createdBy])
  @@map("projects")
}

enum ProjectStatus {
  planning
  in_progress
  on_hold
  completed
  cancelled
}

model ProjectPermission {
  id        Int     @id @default(autoincrement())
  userId    String
  projectId Int
  canView   Boolean @default(true)
  canEdit   Boolean @default(true)
  isOwner   Boolean @default(false)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [supabase_id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([userId])
  @@index([projectId])
  @@index([userId, isOwner])
  @@index([userId, canView])
  @@map("project_permissions")
}

model Client {
  id             String         @id @default(cuid())
  name           String
  email          String         @unique
  phone          String?
  company        String?
  address        String?
  notes          String?
  created_at     DateTime       @default(now())
  updated_at     DateTime       @default(now())
  industry       String?
  membershipType MembershipType @default(NON_MEMBER)
  yearlyRevenue  Float?
  createdById    String
  createdBy      User            @relation("ClientCreator", fields: [createdById], references: [id], onDelete: Restrict, onUpdate: Cascade)
  projects       Project[]
  quotations     Quotation[]

  @@map("clients")
}

model Appointment {
  id              Int                   @id @default(autoincrement())
  name            String
  location        String?
  brand           String?
  description     String?
  appointmentType AppointmentType       @default(OTHERS)
  isAvailable     Boolean               @default(true)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  bookings        AppointmentBooking[]

  @@map("appointments")
}

model AppointmentBooking {
  id              Int             @id @default(autoincrement())
  bookedBy        String
  startDate       DateTime
  endDate         DateTime
  purpose         String?
  appointmentType AppointmentType @default(OTHERS)
  status          String          @default("active")
  projectId       Int?
  appointmentId   Int?
  attendees       Int?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  appointment     Appointment?    @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  project         Project?        @relation("AppointmentBookingProject", fields: [projectId], references: [id], onDelete: SetNull)

  @@map("appointment_bookings")
}

model TimeEntry {
  id          Int       @id @default(autoincrement())
  userId      String
  projectId   Int
  startTime   DateTime
  endTime     DateTime?
  duration    Int
  description String?
  isActive    Boolean   @default(false)
  isPause     Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("time_entries")
}

model ProjectInvitation {
  id          Int              @id @default(autoincrement())
  projectId   Int
  invitedBy   String
  invitedUser String
  status      InvitationStatus @default(pending)
  canView     Boolean          @default(true)
  canEdit     Boolean          @default(true)
  isOwner     Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  inviter     User             @relation("ProjectInviter", fields: [invitedBy], references: [supabase_id], onDelete: Cascade)
  invitee     User             @relation("ProjectInvitee", fields: [invitedUser], references: [supabase_id], onDelete: Cascade)
  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, invitedUser])
  @@map("project_invitations")
}

model Milestone {
  id          Int             @id @default(autoincrement())
  title       String
  description String?
  projectId   Int
  serviceId   Int?
  dueDate     DateTime
  priority    TaskPriority    @default(low)
  status      MilestoneStatus @default(in_progress)
  order       Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  service     Services?       @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  tasks       Task[]

  @@map("milestones")
}

model Task {
  id          Int          @id @default(autoincrement())
  title       String
  description String?
  projectId   Int
  status      TaskStatus   @default(todo)
  priority    TaskPriority @default(low)
  creatorId   String
  dueDate     DateTime
  order       Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  startDate   DateTime
  milestoneId Int?
  assigneeId  String?
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [supabase_id])
  creator     User         @relation("TaskCreator", fields: [creatorId], references: [supabase_id])
  milestone   Milestone?   @relation(fields: [milestoneId], references: [id])
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("tasks")
}

model ServiceToTag {
  A            Int
  B            Int
  service_tags ServiceTag @relation(fields: [A], references: [id], onDelete: Cascade)
  Services     Services   @relation(fields: [B], references: [id], onDelete: Cascade)

  @@id([A, B], map: "_ServiceToTag_AB_pkey")
  @@index([B], map: "_ServiceToTag_B_index")
  @@map("_ServiceToTag")
}

enum MembershipType {
  MEMBER
  NON_MEMBER
}

enum QuotationStatus {
  draft
  in_review
  final
  accepted
  rejected
}

enum DiscountType {
  percentage
  fixed
}

enum TaskStatus {
  todo
  in_progress
  done
}

enum TaskPriority {
  low
  medium
  high
}

enum MilestoneStatus {
  not_started
  in_progress
  completed
}

enum InvitationStatus {
  pending
  accepted
  declined
  expired
  removed
}

enum CustomServiceStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BenefitTier {
  TIER_1
  TIER_2
  TIER_3
  TIER_4
}

enum AppointmentType {
  PHOTO_SHOOT
  VIDEO_SHOOT
  CONSULTATION
  PHOTO_SELECTION
  OTHERS
}

model TierSelection {
  id             String      @id @default(cuid())
  userId         String
  year           Int
  tier           BenefitTier
  customTarget   Int?        // Custom monthly target for Tier 1 (50k-70k)
  selectedAt     DateTime    @default(now())
  adminOverride  Boolean     @default(false)
  adminNote      String?
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year])
  @@map("tier_selections")
}

model Contract {
  id          String   @id @default(cuid())
  projectId   Int
  fileName    String
  filePath    String
  uploadedBy  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploader    User     @relation(fields: [uploadedBy], references: [supabase_id], onDelete: Cascade)

  @@map("contracts")
}

