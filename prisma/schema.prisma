// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Role {
  id    String     @id @default(cuid())
  slug  String     @unique // "admin" | "member"
  users UserRole[]

  @@map("role")
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@map("user_role")
}

model User {
  id                  String              @id @default(cuid())
  firstName           String
  lastName            String
  email               String
  userRoles           UserRole[]
  supabase_id         String              @unique
  created_at          DateTime            @default(now())
  updated_at          DateTime            @default(now())
  quotations          Quotation[]         @relation("QuotationCreator")
  projects            Project[]           @relation("ProjectCreator")
  timeEntries         TimeEntry[]
  projectPermissions  ProjectPermission[]
  sentInvitations     ProjectInvitation[] @relation("ProjectInviter")
  receivedInvitations ProjectInvitation[] @relation("ProjectInvitee")

  @@map("user")
}

model Services {
  id          Int                @id @default(autoincrement())
  name        String
  description String
  basePrice   Float
  created_at  DateTime           @default(now())
  updated_at  DateTime           @default(now())
  quotations  QuotationService[]

  @@map("services")
}

model Quotation {
  id            Int                @id @default(autoincrement())
  name          String
  description   String
  discountValue Float?
  discountType  DiscountType?
  totalPrice    Float
  startDate     DateTime?
  duration      Int? // months unit
  endDate       DateTime?
  services      QuotationService[]
  status        QuotationStatus    @default(draft)
  createdById   String
  projects      Project[]
  created_at    DateTime           @default(now())
  updated_at    DateTime           @default(now())
  createdBy     User               @relation("QuotationCreator", fields: [createdById], references: [supabase_id])
  Client        Client?            @relation(fields: [clientId], references: [id])
  clientId      String?

  @@map("quotations")
}

enum QuotationStatus {
  draft
  sent
  accepted
  rejected
  paid
  unpaid
  partially_paid
  deposit_paid
}

enum DiscountType {
  percentage
  fixed
}

model QuotationService {
  id          Int       @id @default(autoincrement())
  quotationId Int
  serviceId   Int
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  service     Services  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([quotationId, serviceId])
  @@map("quotation_services")
}

model Project {
  id            Int                 @id @default(autoincrement())
  name          String
  description   String?
  quotationId   Int
  quotation     Quotation           @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  createdBy     String?
  createdByUser User?               @relation("ProjectCreator", fields: [createdBy], references: [supabase_id])
  status        String              @default("planning") // "planning" | "in_progress" | "completed" | "cancelled"
  startDate     DateTime?
  endDate       DateTime?
  priority      String              @default("low") // "low" | "medium" | "high"
  created_at    DateTime            @default(now())
  updated_at    DateTime            @default(now())
  timeEntries   TimeEntry[]
  permissions   ProjectPermission[]
  invitations   ProjectInvitation[]
  Client        Client?             @relation(fields: [clientId], references: [id])
  clientId      String?

  @@map("projects")
}

model ProjectPermission {
  id        Int     @id @default(autoincrement())
  userId    String
  projectId Int
  canView   Boolean @default(true)
  canEdit   Boolean @default(true)
  isOwner   Boolean @default(false)

  user    User    @relation(fields: [userId], references: [supabase_id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@map("project_permissions")
}

model Client {
  id         String      @id @default(cuid())
  name       String
  email      String      @unique
  phone      String?
  company    String?
  address    String?
  notes      String?
  quotations Quotation[]
  projects   Project[]
  created_at DateTime    @default(now())
  updated_at DateTime    @default(now())

  @@map("clients")
}

model Studio {
  id          Int             @id @default(autoincrement())
  name        String
  location    String
  capacity    Int
  description String?
  isActive    Boolean         @default(true)
  bookings    StudioBooking[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("studios")
}

model Equipment {
  id           Int       @id @default(autoincrement())
  name         String
  type         String
  brand        String?
  model        String?
  serialNumber String?   @unique
  condition    String    @default("Good")
  isAvailable  Boolean   @default(true)
  bookings     Booking[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("equipment")
}

model Booking {
  id          Int       @id @default(autoincrement())
  equipmentId Int
  equipment   Equipment @relation(fields: [equipmentId], references: [id])
  bookedBy    String
  startDate   DateTime
  endDate     DateTime
  purpose     String?
  status      String    @default("active") // "active" | "cancelled" | "completed"
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("bookings")
}

model StudioBooking {
  id        Int      @id @default(autoincrement())
  studioId  Int
  studio    Studio   @relation(fields: [studioId], references: [id])
  bookedBy  String
  startDate DateTime
  endDate   DateTime
  purpose   String?
  attendees Int      @default(1)
  status    String   @default("active") // "active" | "cancelled" | "completed"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("studio_bookings")
}

model TimeEntry {
  id          Int       @id @default(autoincrement())
  userId      String
  projectId   Int
  startTime   DateTime
  endTime     DateTime?
  duration    Int
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("time_entries")
}

model ProjectInvitation {
  id          Int              @id @default(autoincrement())
  projectId   Int
  invitedBy   String
  invitedUser String
  status      InvitationStatus @default(pending)
  canView     Boolean          @default(true)
  canEdit     Boolean          @default(true)
  isOwner     Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  inviter User    @relation("ProjectInviter", fields: [invitedBy], references: [supabase_id], onDelete: Cascade)
  invitee User    @relation("ProjectInvitee", fields: [invitedUser], references: [supabase_id], onDelete: Cascade)

  @@unique([projectId, invitedUser])
  @@map("project_invitations")
}

enum InvitationStatus {
  pending
  accepted
  declined
  expired
}
